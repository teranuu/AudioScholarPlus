    <string name="about_app_version_format">Version %1$s</string>
    <string name="about_app_tagline">Empowering learners through intelligent audio insights.</string>
    <string name="about_app_description">AudioScholar is a smart, student-focused platform that transforms lecture audio into structured summaries and personalized learning resources. Designed for learners, it simplifies note-taking, enhances comprehension, and bridges the gap between passive listening and active understanding — all powered by AI and accessible across devices.</string>
