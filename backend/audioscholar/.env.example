# Spring profile/configuration
SPRING_PROFILES_ACTIVE=local
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,capacitor://localhost

# Firebase / Google Cloud
FIREBASE_WEB_API_KEY=
FIREBASE_DATABASE_URL=https://audioscholar-20260521.firebaseio.com
FIREBASE_PROJECT_ID=audioscholar-20260521
# Path to Firebase service-account JSON on the filesystem (required for production/staging).
# The JSON is excluded from the jar by pom.xml — always use this env var outside local dev.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_AI_API_KEY=
GEMINI_API_KEYS=
YOUTUBE_API_KEY=


# Supabase Postgres / Storage — audioscholar project (ref: jqnwetnvnmlqbhwivrxy, region: us-west-1)
# Dashboard: https://supabase.com/dashboard/project/jqnwetnvnmlqbhwivrxy
#
# Copy from Dashboard → Project Settings → Database → Connection string (URI, port 6543 session pooler recommended)
DATABASE_URL=jdbc:postgresql://aws-0-us-west-1.pooler.supabase.com:6543/postgres?user=postgres.jqnwetnvnmlqbhwivrxy
DATABASE_USERNAME=postgres.jqnwetnvnmlqbhwivrxy
DATABASE_PASSWORD=
# Copy from Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://jqnwetnvnmlqbhwivrxy.supabase.co
# Copy from Dashboard → Project Settings → API → service_role (secret, JWT token)
SUPABASE_SERVICE_ROLE_KEY=
# Copy from Dashboard → Project Settings → API → anon/public (publishable key)
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=audioscholar


# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


# Authentication
JWT_SECRET=
JWT_EXPIRATION_MS=3600000

# External services
UPTIME_ROBOT_API=
NVD_API_KEY=
AI_PROVIDER=gemini
AI_OPENAI_COMPATIBLE_ENABLED=false
AI_OPENAI_COMPATIBLE_BASE_URL=https://opencode.ai/zen/v1
AI_OPENAI_COMPATIBLE_API_KEY=
AI_OPENAI_COMPATIBLE_CHAT_MODEL=big-pickle
AI_OPENAI_COMPATIBLE_RETRY_MAX_ATTEMPTS=3
AI_OPENAI_COMPATIBLE_RETRY_INITIAL_BACKOFF_MS=1000
AI_OPENAI_COMPATIBLE_RETRY_MAX_BACKOFF_MS=60000
# Portfolio/demo default: false keeps Rabbit listener beans and Rabbit Actuator health disabled.
# Set true only when RabbitMQ is provisioned for legacy/full async processing.
APP_RABBITMQ_ENABLED=false
APP_ASYNC_CORE_POOL_SIZE=2
APP_ASYNC_MAX_POOL_SIZE=4
APP_ASYNC_QUEUE_CAPACITY=20
TEMP_FILE_DIR=